CompileFlags:
  CompilationDatabase: build
  Remove:
    - -mno-direct-extern-access
  Add:
    - -isystem
    - /usr/include/qt6
    - -isystem
    - /usr/include/qt6/QtCore
    - -isystem
    - /usr/include/qt6/QtGui
    - -isystem
    - /usr/include/qt6/QtWidgets
    - -isystem
    - /usr/lib/qt6/mkspecs/linux-g++
